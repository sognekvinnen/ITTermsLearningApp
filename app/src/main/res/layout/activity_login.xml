<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    style="@style/BaseScreen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginActivity"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/tvLoginWarning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/login_welcome_text"
        android:textSize="20sp"
        android:textColor="@color/welcomecolor"
        android:gravity="center"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.4" />

    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"

        app:layout_constraintTop_toBottomOf="@id/tvLoginWarning"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">


        <Button
            android:id="@+id/btnAuthorisation"
            style="@style/AppButton"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Войти в аккаунт"
            android:textSize="18sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnRegistration"
            style="@style/AppButton"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Зарегистрироваться"
            android:textSize="18sp"
            android:layout_marginBottom="18dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>


